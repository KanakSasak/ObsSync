{
  "name": "obssync",
  "version": "0.1.0",
  "description": "Sync an Obsidian vault to a private GitHub repository",
  "type": "module",
  "main": "./main.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "obssync": "./dist/cli.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:cli": "node esbuild.config.mjs --cli",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "tsc --noEmit",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "dependencies": {
    "isomorphic-git": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "chalk": "^5.4.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "simple-git": "^3.27.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "obsidian",
    "git",
    "sync",
    "vault",
    "github"
  ],
  "license": "MIT"
}
